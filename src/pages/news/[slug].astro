---
import { getCollection } from "astro:content";
import Base from "../../components/layout/Base.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import { slugify } from "../../lib/constants";

export async function getStaticPaths() {
  const news = await getCollection("news");
  return news.map((item) => ({ params: { slug: slugify(item.id) } }));
}

const { slug } = Astro.params;
const allNews = await getCollection("news", ({ data }) => !data.draft);
const entry = allNews.find(i => slugify(i.id) === slug);
if (!entry) return Astro.redirect("/news");

const { Content } = await entry.render();

const relatedArticles = allNews
  .filter(i => slugify(i.id) !== slug)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<Base title={entry.data.title} description={entry.data.summary} image={entry.data.image}>
  <Header />
  <main class="fade-in">
    <article>
      <!-- Contained Cinematic Hero -->
      <div class="max-w-5xl mx-auto px-6 pt-12 pb-10">
        {entry.data.image && (
          <img
            src={entry.data.image}
            alt={entry.data.title}
            class="w-full object-cover"
            style="aspect-ratio: 21/9;"
            loading="eager"
          />
        )}
      </div>

      <!-- Article header: meta + title + lead -->
      <div class="max-w-3xl mx-auto px-6">
        <div class="article-meta mb-4">
          {entry.data.author === "manual" ? "EDITORIAL" : "AI · GENERATED"}
          {entry.data.source && ` · ${entry.data.source.toUpperCase()}`}
          <br />
          {entry.data.date.toLocaleDateString("zh-CN", { year: "numeric", month: "2-digit", day: "2-digit" })}
        </div>

        <h1 class="article-title mb-6">{entry.data.title}</h1>

        {entry.data.summary && (
          <p class="article-lead mb-10">{entry.data.summary}</p>
        )}
      </div>

      <!-- Article body -->
      <div class="max-w-3xl mx-auto px-6 prose">
        <Content />
      </div>

      <!-- Pull Quote (from frontmatter) -->
      {entry.data.pullQuote && (
        <div class="max-w-3xl mx-auto px-6">
          <blockquote class="article-quote">{entry.data.pullQuote}</blockquote>
        </div>
      )}

      <!-- Section Break -->
      <div class="max-w-3xl mx-auto px-6">
        <hr class="article-section-break" />
      </div>

      <!-- Related Articles -->
      <div class="max-w-3xl mx-auto px-6 pb-20">
        <p class="article-meta mb-6">继续阅读</p>
        <div class="space-y-5">
          {relatedArticles.map(item => (
            <a
              href={`/news/${slugify(item.id)}`}
              class="group block border-t border-surface-border pt-5"
            >
              <div class="article-meta mb-1">
                {item.data.date.toLocaleDateString("zh-CN", { year: "numeric", month: "2-digit", day: "2-digit" })}
                {item.data.source && ` · ${item.data.source}`}
              </div>
              <h3 class="font-brand font-semibold text-lg text-text-primary group-hover:text-accent-blue transition-colors leading-snug">
                {item.data.title}
              </h3>
            </a>
          ))}
        </div>
      </div>
    </article>
  </main>
  <Footer />
</Base>
