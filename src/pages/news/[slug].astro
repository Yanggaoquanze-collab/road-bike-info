---
import { getCollection } from "astro:content";
import Base from "../../components/layout/Base.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import TagPill from "../../components/shared/TagPill.astro";
import GiscusComments from "../../components/shared/GiscusComments.svelte";
import { slugify } from "../../lib/constants";

export async function getStaticPaths() {
  const news = await getCollection("news");
  return news.map((item) => ({ params: { slug: slugify(item.id) } }));
}

const { slug } = Astro.params;
const entry = await getCollection("news").then(items => items.find(i => slugify(i.id) === slug));
if (!entry) return Astro.redirect("/news");

const { Content } = await entry.render();
---

<Base title={entry.data.title} description={entry.data.summary} image={entry.data.image}>
  <Header />
  <main class="mx-auto max-w-3xl px-6 py-12 fade-in">
    <a href="/news" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors mb-6 inline-block">&larr; 返回新闻列表</a>
    <article>
      <div class="mb-8">
        <div class="flex items-center gap-3 mb-3">
          <TagPill label={entry.data.author === "AI" ? "AI 生成" : "人工撰写"} color={entry.data.author === "AI" ? "purple" : "green"} />
          {entry.data.source && <TagPill label={entry.data.source} />}
        </div>
        <h1 class="text-3xl font-bold text-text-primary mb-3">{entry.data.title}</h1>
        <time class="text-sm text-text-tertiary">{entry.data.date.toISOString().slice(0, 10)}</time>
        {entry.data.sourceUrl && (
          <a href={entry.data.sourceUrl} target="_blank" rel="noopener" class="ml-4 text-sm text-accent-blue hover:underline">查看原文</a>
        )}
      </div>
      <div class="prose prose-invert max-w-none">
        <Content />
      </div>
    </article>
    <GiscusComments client:load />
  </main>
  <Footer />
</Base>
