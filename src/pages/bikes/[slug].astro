---
import { getCollection } from "astro:content";
import Base from "../../components/layout/Base.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import BikeSpecTable from "../../components/bikes/BikeSpecTable.astro";
import { BIKE_CATEGORIES, PRICE_RANGES, slugify } from "../../lib/constants";

export async function getStaticPaths() {
  const bikes = await getCollection("bikes");
  return bikes.map((item) => ({ params: { slug: slugify(item.id) } }));
}

const { slug } = Astro.params;
const allBikes = await getCollection("bikes", ({ data }) => !data.draft);
const entry = allBikes.find(i => slugify(i.id) === slug);
if (!entry) return Astro.redirect("/bikes");

const { Content } = await entry.render();
const catLabel = BIKE_CATEGORIES[entry.data.category];
const priceLabel = PRICE_RANGES[entry.data.priceRange].label;
const formattedPrice = entry.data.price >= 10000 ? `${(entry.data.price / 10000).toFixed(2)} 万` : `¥${entry.data.price.toLocaleString()}`;
---

<Base title={entry.data.title} description={`${entry.data.brand} ${entry.data.model} — ${entry.data.groupset}, ${entry.data.weight}kg`} image={entry.data.image}>
  <Header />
  <main class="fade-in">
    <article>
      <!-- Contained product hero — 4:5 product ratio -->
      <div class="max-w-4xl mx-auto px-6 pt-12 pb-8">
        <img
          src={entry.data.image}
          alt={entry.data.title}
          class="w-full h-auto object-cover"
          loading="eager"
        />
      </div>

      <!-- Brand meta + model name (serif only here) + price -->
      <div class="max-w-3xl mx-auto px-6">
        <div class="flex items-center gap-3 article-meta mb-3">
          <span>{entry.data.brand}</span>
          <span class="opacity-25">·</span>
          <span>{catLabel}</span>
          <span class="opacity-25">·</span>
          <span>{priceLabel}</span>
        </div>

        <h1 class="font-brand font-semibold text-text-primary mb-2"
          style="font-size: clamp(1.75rem, 3vw, 2.25rem); letter-spacing: -0.02em; line-height: 1.15; color: #1a1a1a;">
          {entry.data.model}
        </h1>

        <p class="text-2xl font-light text-text-secondary mb-10">{formattedPrice}</p>

        {entry.data.summary && (
          <p class="text-body mb-12">{entry.data.summary}</p>
        )}
      </div>

      <!-- Spec table — fine-line rows -->
      <div class="max-w-3xl mx-auto px-6 mb-12">
        <BikeSpecTable bike={entry.data} />
      </div>

      <!-- Body — minimal prose -->
      <div class="max-w-3xl mx-auto px-6 prose">
        <Content />
      </div>

      <!-- Official link -->
      {entry.data.officialUrl && (
        <div class="max-w-3xl mx-auto px-6 mt-8 pb-20">
          <a
            href={entry.data.officialUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-text-tertiary hover:text-text-secondary transition-colors"
          >
            查看官网 &rarr;
          </a>
        </div>
      )}
    </article>
  </main>
  <Footer />
</Base>
