---
import { getCollection } from "astro:content";
import Base from "../../components/layout/Base.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import BikeMagazineCard from "../../components/bikes/BikeMagazineCard.astro";
import { slugify } from "../../lib/constants";

const allBikes = await getCollection("bikes", ({ data }) => !data.draft);
---

<Base title="车型库" description="最新公路车数据 — Giant、Trek、Specialized、Canyon 等品牌，详细配置与对比">
  <Header />
  <main class="mx-auto max-w-[1200px] px-6 py-16 fade-in">
    <div class="mb-12">
      <h1 class="section-title mb-1">车型库</h1>
      <p class="section-subtitle">值得关注的最新公路车</p>
    </div>

    <div class="grid gap-x-6 gap-y-10 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
      {allBikes.map(item => (
        <BikeMagazineCard {...item.data} slug={slugify(item.id)} />
      ))}
    </div>
  </main>
  <Footer />
</Base>
