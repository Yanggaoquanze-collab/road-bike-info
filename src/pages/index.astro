---
import { getCollection } from "astro:content";
import Base from "../components/layout/Base.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import HeroBike from "../components/homepage/HeroBike.astro";
import FeaturedCards from "../components/homepage/FeaturedCards.astro";
import LatestNews from "../components/homepage/LatestNews.astro";
import UpcomingEvents from "../components/homepage/UpcomingEvents.astro";
import SymptomSearchInline from "../components/homepage/SymptomSearchInline.svelte";
import PopularModels from "../components/homepage/PopularModels.astro";

const news = await getCollection("news", ({ data }) => !data.draft);
const sortedNews = news.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 3);

const events = await getCollection("events", ({ data }) => !data.draft && data.status === "upcoming");
const sortedEvents = events.sort((a, b) => a.data.startDate.getTime() - b.data.startDate.getTime()).slice(0, 3);

const bikes = await getCollection("bikes", ({ data }) => !data.draft);
const featuredBikes = bikes.slice(0, 4);
---

<Base description="公路车新闻、赛事、维修排查、车型库 — 为骑行爱好者提供一站式信息平台">
  <Header />
  <main>
    <section class="relative overflow-hidden pt-12 md:pt-20 pb-20 md:pb-28">
      <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(circle at 50% 0%, rgba(200,60,40,0.08), transparent 60%);" />
      <!-- Geometric line art background -->
      <div class="absolute inset-0 pointer-events-none flex items-center justify-center opacity-[0.07]">
        <img src="/images/hero-line-art.svg" alt="" class="max-w-[700px] w-full text-accent-blue" aria-hidden="true" />
      </div>
      <HeroBike />
    </section>

    <FeaturedCards />

    <section class="mx-auto max-w-[1200px] px-6 py-20">
      <LatestNews items={sortedNews} />
    </section>

    <section class="bg-bg-secondary/50 py-20">
      <div class="mx-auto max-w-[1200px] px-6">
        <UpcomingEvents items={sortedEvents} />
      </div>
    </section>

    <section class="mx-auto max-w-[1200px] px-6 py-20">
      <div class="mb-8 text-center">
        <h2 class="text-2xl font-bold text-text-primary mb-3">快速排查</h2>
        <p class="text-text-tertiary">描述你的症状，找到解决方案</p>
      </div>
      <SymptomSearchInline client:load />
    </section>

    <section class="bg-bg-secondary/50 py-20">
      <div class="mx-auto max-w-[1200px] px-6">
        <PopularModels items={featuredBikes} />
      </div>
    </section>
  </main>
  <Footer />
</Base>
