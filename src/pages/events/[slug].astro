---
import { getCollection } from "astro:content";
import Base from "../../components/layout/Base.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import { EVENT_LEVELS, EVENT_TYPES, slugify } from "../../lib/constants";

export async function getStaticPaths() {
  const events = await getCollection("events");
  return events.map((item) => ({ params: { slug: slugify(item.id) } }));
}

const { slug } = Astro.params;
const allEvents = await getCollection("events", ({ data }) => !data.draft);
const entry = allEvents.find(i => slugify(i.id) === slug);
if (!entry) return Astro.redirect("/events");

const { Content } = await entry.render();
const level = EVENT_LEVELS[entry.data.level];
const typeLabel = EVENT_TYPES[entry.data.type];
const statusLabel = entry.data.status === "upcoming" ? "即将开始" : entry.data.status === "ongoing" ? "进行中" : "已结束";

const dateRange = entry.data.startDate.getTime() === entry.data.endDate.getTime()
  ? entry.data.startDate.toLocaleDateString("zh-CN", { year: "numeric", month: "2-digit", day: "2-digit" })
  : `${entry.data.startDate.toLocaleDateString("zh-CN", { year: "numeric", month: "2-digit", day: "2-digit" })} — ${entry.data.endDate.toLocaleDateString("zh-CN", { year: "numeric", month: "2-digit", day: "2-digit" })}`;
---

<Base title={entry.data.title} description={entry.data.summary} image={entry.data.routeMap}>
  <Header />
  <main class="fade-in">
    <article>
      <!-- Contained Hero — route map or event image -->
      {entry.data.routeMap && (
        <div class="max-w-5xl mx-auto px-6 pt-12 pb-10">
          <img
            src={entry.data.routeMap}
            alt={`${entry.data.title} 路线图`}
            class="w-full object-cover"
            style="aspect-ratio: 21/9;"
            loading="eager"
          />
        </div>
      )}

      <div class="max-w-3xl mx-auto px-6">
        <!-- Timeline-style meta -->
        <div class="article-meta mb-4">
          {dateRange}
          <br />
          {entry.data.location}，{entry.data.country}
        </div>

        <h1 class="article-title mb-2">{entry.data.title}</h1>
        {entry.data.titleEn && <p class="text-lg text-text-tertiary mb-6">{entry.data.titleEn}</p>}

        <div class="flex items-center gap-3 article-meta mb-10">
          <span>{level.label}</span>
          <span class="opacity-25">·</span>
          <span>{typeLabel}</span>
          <span class="opacity-25">·</span>
          <span>{statusLabel}</span>
        </div>

        {entry.data.summary && (
          <p class="article-lead mb-10">{entry.data.summary}</p>
        )}
      </div>

      <!-- Body -->
      <div class="max-w-3xl mx-auto px-6 prose">
        <Content />
      </div>

      <!-- Registration link -->
      {entry.data.status === "upcoming" && entry.data.registrationUrl && (
        <div class="max-w-3xl mx-auto px-6 mt-8 pb-20">
          <a
            href={entry.data.registrationUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-text-tertiary hover:text-text-secondary transition-colors"
          >
            前往报名 &rarr;
          </a>
        </div>
      )}

      {(!entry.data.registrationUrl || entry.data.status !== "upcoming") && (
        <div class="pb-20"></div>
      )}
    </article>
  </main>
  <Footer />
</Base>
