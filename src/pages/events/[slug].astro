---
import { getCollection } from "astro:content";
import Base from "../../components/layout/Base.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import Badge from "../../components/shared/Badge.astro";
import TagPill from "../../components/shared/TagPill.astro";
import { EVENT_LEVELS, EVENT_TYPES } from "../../lib/constants";
import GiscusComments from "../../components/shared/GiscusComments.svelte";

export async function getStaticPaths() {
  const events = await getCollection("events");
  return events.map((item) => ({ params: { slug: item.id } }));
}

const { slug } = Astro.params;
const entry = await getCollection("events").then(items => items.find(i => i.id === slug));
if (!entry) return Astro.redirect("/events");

const { Content } = await entry.render();
const level = EVENT_LEVELS[entry.data.level];
const typeLabel = EVENT_TYPES[entry.data.type];
---

<Base title={entry.data.title} description={entry.data.summary} image={entry.data.routeMap}>
  <Header />
  <main class="mx-auto max-w-3xl px-6 py-12 fade-in">
    <a href="/events" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors mb-6 inline-block">&larr; 返回赛事列表</a>
    <article>
      <div class="mb-8">
        <div class="flex flex-wrap items-center gap-2 mb-3">
          <Badge label={level.label} color={level.color} />
          <Badge label={entry.data.status === "upcoming" ? "即将开始" : entry.data.status === "ongoing" ? "进行中" : "已结束"} color={entry.data.status === "upcoming" ? "green" : entry.data.status === "ongoing" ? "amber" : "default"} variant="outline" />
          <TagPill label={typeLabel} />
          <TagPill label={entry.data.region === "domestic" ? "国内" : "国际"} color={entry.data.region === "domestic" ? "green" : "blue"} />
        </div>
        <h1 class="text-3xl font-bold text-text-primary mb-2">{entry.data.title}</h1>
        {entry.data.titleEn && <p class="text-lg text-text-tertiary mb-4">{entry.data.titleEn}</p>}
        <p class="text-text-secondary">{entry.data.summary}</p>
      </div>

      <div class="card p-6 mb-8 grid gap-4 sm:grid-cols-2">
        <div>
          <span class="text-xs text-text-tertiary uppercase tracking-wider">日期</span>
          <p class="text-text-primary font-medium">
            {entry.data.startDate.toISOString().slice(0, 10)}
            {entry.data.startDate.getTime() !== entry.data.endDate.getTime() &&
              ` — ${entry.data.endDate.toISOString().slice(0, 10)}`}
          </p>
        </div>
        <div>
          <span class="text-xs text-text-tertiary uppercase tracking-wider">地点</span>
          <p class="text-text-primary font-medium">{entry.data.location}，{entry.data.country}</p>
        </div>
        <div>
          <span class="text-xs text-text-tertiary uppercase tracking-wider">类型</span>
          <p class="text-text-primary font-medium">{typeLabel}</p>
        </div>
        <div>
          <span class="text-xs text-text-tertiary uppercase tracking-wider">等级</span>
          <p class="text-text-primary font-medium">{level.label}</p>
        </div>
      </div>

      {entry.data.routeMap && (
        <img src={entry.data.routeMap} alt={`${entry.data.title} 路线图`} class="rounded-xl w-full mb-8" loading="lazy" />
      )}

      {entry.data.status === "upcoming" && entry.data.registrationUrl && (
        <a href={entry.data.registrationUrl} target="_blank" rel="noopener" class="inline-block mb-8 px-6 py-3 bg-accent-blue text-white font-semibold rounded-xl hover:bg-blue-600 transition-colors">
          前往报名
        </a>
      )}

      <div class="prose prose-invert max-w-none">
        <Content />
      </div>
    </article>
    <GiscusComments client:load />
  </main>
  <Footer />
</Base>
