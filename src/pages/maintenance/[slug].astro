---
import { getCollection } from "astro:content";
import Base from "../../components/layout/Base.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import { DIFFICULTY, slugify } from "../../lib/constants";

export async function getStaticPaths() {
  const items = await getCollection("maintenance");
  return items.map((item) => ({ params: { slug: slugify(item.id) } }));
}

const { slug } = Astro.params;
const entry = await getCollection("maintenance").then(items => items.find(i => slugify(i.id) === slug));
if (!entry) return Astro.redirect("/maintenance");

const { Content } = await entry.render();
const diff = DIFFICULTY[entry.data.difficulty];
---

<Base title={entry.data.title} description={entry.data.symptoms?.join("、")}>
  <Header />
  <main class="py-16 fade-in" style="background: #efefec; min-height: calc(100vh - 180px);">
    <div class="max-w-3xl mx-auto px-6">
      <a href="/maintenance" class="text-meta hover:text-text-secondary transition-colors inline-block mb-10">&larr; Workshop Notes</a>

      <article>
        <div class="article-meta mb-3">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-text-tertiary align-middle mr-1.5"></span>
          {diff.label}
          <span class="mx-2" style="color: rgba(0,0,0,.16);">·</span>
          {entry.data.category}
        </div>

        <h1 class="article-title mb-8">{entry.data.title}</h1>

        <p class="text-meta mb-12">
          {entry.data.symptoms.join(" · ")}
        </p>

        <div class="prose max-w-none">
          <Content />
        </div>
      </article>
    </div>
  </main>
  <Footer />
</Base>
