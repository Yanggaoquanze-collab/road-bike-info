---
import { getCollection } from "astro:content";
import Base from "../../components/layout/Base.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import TagPill from "../../components/shared/TagPill.astro";
import Badge from "../../components/shared/Badge.astro";
import { DIFFICULTY, slugify } from "../../lib/constants";
import GiscusComments from "../../components/shared/GiscusComments.svelte";

export async function getStaticPaths() {
  const items = await getCollection("maintenance");
  return items.map((item) => ({ params: { slug: slugify(item.id) } }));
}

const { slug } = Astro.params;
const entry = await getCollection("maintenance").then(items => items.find(i => slugify(i.id) === slug));
if (!entry) return Astro.redirect("/maintenance");

const { Content } = await entry.render();
const diff = DIFFICULTY[entry.data.difficulty];
---

<Base title={entry.data.title} description={entry.data.symptoms?.join("、")}>
  <Header />
  <main class="mx-auto max-w-3xl px-6 py-16 fade-in">
    <a href="/maintenance" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors mb-6 inline-block">&larr; 返回维修列表</a>
    <article>
      <div class="mb-8">
        <div class="flex flex-wrap items-center gap-2 mb-3">
          <Badge label={diff.label} color={diff.color} />
          <TagPill label={entry.data.category} color="blue" />
        </div>
        <h1 class="text-2xl font-bold text-text-primary mb-4">{entry.data.title}</h1>
        <div class="flex flex-wrap gap-2">
          {entry.data.symptoms.map(s => <TagPill label={s} size="sm" />)}
        </div>
      </div>
      <div class="prose max-w-none">
        <Content />
      </div>
    </article>
    <GiscusComments client:load />
  </main>
  <Footer />
</Base>
