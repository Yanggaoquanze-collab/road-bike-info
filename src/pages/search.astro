---
import Base from "../components/layout/Base.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import SearchPage from "../components/shared/SearchPage.svelte";
---

<Base title="搜索" description="搜索全站内容 — 新闻、赛事、维修指南、车型数据">
  <Header />
  <main class="min-h-[calc(100vh-200px)]">
    <div class="mx-auto max-w-[1200px] px-6 py-12">
      <h2 class="text-2xl font-semibold text-text-primary mb-8">搜索</h2>
      <SearchPage client:load />
    </div>
  </main>
  <Footer />
</Base>
