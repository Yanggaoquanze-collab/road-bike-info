---
interface Props {
  title: string;
  date: Date;
  author: string;
  source?: string;
  tags: string[];
  summary: string;
  image?: string;
  slug: string;
}

const { title, date, source, summary, image, slug } = Astro.props;
---

<a href={`/news/${slug}`} class="group block py-5 border-t border-surface-border">
  {image && (
    <div class="aspect-[16/9] overflow-hidden bg-bg-tertiary mb-3">
      <img src={image} alt={title} class="w-full h-full object-cover motion-image group-hover:scale-[1.02]" loading="lazy" />
    </div>
  )}
  <div class="flex items-center gap-2 mb-1.5 text-meta">
    <span>{date.toISOString().slice(0, 10)}</span>
    {source && <><span class="text-text-tertiary/40">·</span><span class="text-accent-blue font-medium">{source}</span></>}
  </div>
  <h3 class="font-brand font-semibold text-text-primary group-hover:text-accent-blue transition-colors leading-[1.35] text-lg mb-1.5">{title}</h3>
  <p class="text-sm text-text-tertiary leading-relaxed line-clamp-2">{summary}</p>
</a>
