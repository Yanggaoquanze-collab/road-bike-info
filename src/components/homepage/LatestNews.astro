---
import type { CollectionEntry } from "astro:content";
import NewsCard from "../news/NewsCard.astro";
import { slugify } from "../../lib/constants";

interface Props {
  items: CollectionEntry<"news">[];
}

const { items } = Astro.props;
const [first, ...rest] = items;
---

<div>
  <div class="mb-8">
    <h2 class="section-title mb-1">最新动态</h2>
    <p class="section-subtitle">骑行圈最新报道与深度选题</p>
    <a href="/news" class="inline-block text-sm text-text-tertiary hover:text-text-secondary transition-colors mt-3">全部文章 &rarr;</a>
  </div>

  <!-- Main featured article — no card, full bleed image -->
  {first && (
    <a href={`/news/${slugify(first.id)}`} class="group block mb-16">
      <div class="aspect-[16/9] overflow-hidden bg-bg-tertiary mb-5">
        {first.data.image ? (
          <img src={first.data.image} alt={first.data.title} class="w-full h-full object-cover motion-image group-hover:scale-[1.02]" loading="eager" />
        ) : (
          <div class="w-full h-full flex items-center justify-center text-text-tertiary/15">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
        )}
      </div>
      <div class="flex items-center gap-3 mb-2 text-meta">
        <span>{first.data.date.toISOString().slice(0, 10)}</span>
        {first.data.source && <span class="text-accent-blue font-medium">{first.data.source}</span>}
      </div>
      <h3 class="font-brand font-semibold text-text-primary group-hover:text-accent-blue transition-colors leading-[1.25]"
          style="font-size: clamp(1.5rem, 2.5vw, 2.25rem);">
        {first.data.title}
      </h3>
      <p class="text-body mt-3 max-w-2xl">{first.data.summary}</p>
    </a>
  )}

  <!-- Secondary articles — clean text list, separated by rules -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-0">
    {rest.slice(0, 2).map((item) => (
      <NewsCard {...item.data} slug={slugify(item.id)} />
    ))}
  </div>
</div>
