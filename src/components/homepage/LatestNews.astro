---
import type { CollectionEntry } from "astro:content";
import NewsCard from "../news/NewsCard.astro";
import { slugify } from "../../lib/constants";

interface Props {
  items: CollectionEntry<"news">[];
}

const { items } = Astro.props;
const [first, ...rest] = items;
---

<div>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-xl font-bold text-text-primary">最新动态</h2>
      <p class="text-sm text-text-tertiary mt-1">公路车领域最新新闻</p>
    </div>
    <a href="/news" class="text-sm text-accent-blue hover:text-accent-blue transition-colors">查看全部 &rarr;</a>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-[1.5fr_1fr] gap-5">
    {first && (
      <a href={`/news/${slugify(first.id)}`} class="card overflow-hidden group row-span-2">
        <div class="aspect-[16/10] overflow-hidden bg-bg-tertiary">
          {first.data.image && <img src={first.data.image} alt={first.data.title} class="w-full h-full object-cover motion-image group-hover:scale-[1.02]" />}
        </div>
        <div class="p-5">
          <h3 class="text-xl font-bold text-text-primary group-hover:text-accent-blue transition-colors mb-2">{first.data.title}</h3>
          <p class="text-sm text-text-secondary line-clamp-3">{first.data.summary}</p>
          <span class="text-xs text-text-tertiary mt-3 inline-block">{first.data.date.toISOString().slice(0, 10)}</span>
        </div>
      </a>
    )}

    <div class="flex flex-col gap-4">
      {rest.slice(0, 2).map(item => (
        <NewsCard {...item.data} slug={slugify(item.id)} />
      ))}
    </div>
  </div>
</div>
