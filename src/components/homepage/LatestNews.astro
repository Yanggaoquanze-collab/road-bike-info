---
import type { CollectionEntry } from "astro:content";
import NewsCard from "../news/NewsCard.astro";
import { slugify } from "../../lib/constants";

interface Props {
  items: CollectionEntry<"news">[];
}

const { items } = Astro.props;
const [first, ...rest] = items;
---

<div>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-xl font-bold text-text-primary">最新动态</h2>
      <p class="text-sm text-text-tertiary mt-1">骑行圈最新报道与深度选题</p>
    </div>
    <a href="/news" class="text-sm text-accent-blue hover:text-accent-blue transition-colors">全部文章 &rarr;</a>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-[1.5fr_1fr] gap-5">
    {first && (
      <a href={`/news/${slugify(first.id)}`} class="card overflow-hidden group row-span-2">
        <div class="aspect-[16/10] overflow-hidden bg-bg-tertiary relative">
          {first.data.image ? (
            <img src={first.data.image} alt={first.data.title} class="w-full h-full object-cover motion-image group-hover:scale-[1.02]" />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-text-tertiary/20">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            </div>
          )}
          <span class="absolute top-3 left-3 px-2.5 py-1 rounded-full text-[11px] font-medium bg-black/60 text-white backdrop-blur-sm tracking-wide">
            编辑推荐
          </span>
        </div>
        <div class="p-5">
          <div class="flex items-center gap-2 mb-2 flex-wrap">
            {first.data.source && <span class="font-data text-[11px] font-medium text-accent-blue uppercase tracking-wider">{first.data.source}</span>}
            {first.data.tags.slice(0, 2).map(t => (
              <span class="font-data text-[11px] text-text-tertiary px-2 py-0.5 rounded-full bg-bg-tertiary">{t}</span>
            ))}
          </div>
          <h3 class="font-brand font-semibold text-2xl text-text-primary group-hover:text-accent-blue transition-colors mb-2 leading-[1.3]">{first.data.title}</h3>
          <p class="text-sm text-text-secondary line-clamp-3">{first.data.summary}</p>
          <span class="font-data text-xs text-text-tertiary mt-3 inline-block">{first.data.date.toISOString().slice(0, 10)}</span>
        </div>
      </a>
    )}

    <div class="flex flex-col gap-4">
      {rest.slice(0, 2).map((item, i) => (
        <NewsCard {...item.data} slug={slugify(item.id)} />
      ))}
    </div>
  </div>
</div>
