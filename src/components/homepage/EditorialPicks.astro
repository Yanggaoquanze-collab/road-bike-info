---
import { slugify } from "../../lib/constants";

interface FeatureItem {
  id: string;
  collection: "news" | "events";
  title: string;
  summary: string;
  image?: string;
  date: Date;
  tags: string[];
  slug: string;
}

interface Props {
  items: FeatureItem[];
}

const { items } = Astro.props;
const [first, ...rest] = items;
---

<div class="max-w-[1200px] mx-auto px-6 py-16 md:py-20">
  <div class="mb-8">
    <h2 class="text-2xl font-bold text-text-primary">编辑精选</h2>
    <p class="text-sm text-text-tertiary mt-1">用心挑选的骑行故事</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5">
    <!-- Big card: first featured item, spans 2 columns -->
    <a href={`/${first.collection}/${first.slug}`} class="card overflow-hidden group md:col-span-2 stagger-item stagger-1">
      <div class="aspect-[16/9] overflow-hidden bg-bg-tertiary">
        {first.image ? (
          <img src={first.image} alt={first.title} class="w-full h-full object-cover motion-image group-hover:scale-[1.02]" loading="eager" />
        ) : (
          <div class="w-full h-full flex items-center justify-center text-text-tertiary/20">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
        )}
      </div>
      <div class="p-5 md:p-6">
        <span class="text-xs font-medium uppercase tracking-wider text-accent-blue mb-2 inline-block">
          {first.collection === "news" ? "新闻" : "赛事"}
        </span>
        <h3 class="text-xl md:text-2xl font-bold text-text-primary group-hover:text-accent-blue transition-colors mb-2">{first.title}</h3>
        <p class="text-sm text-text-secondary line-clamp-2">{first.summary}</p>
        <span class="text-xs text-text-tertiary mt-3 inline-block">{first.date.toISOString().slice(0, 10)}</span>
      </div>
    </a>

    <!-- Small cards: remaining 2 items -->
    {rest.map((item, i) => (
      <a href={`/${item.collection}/${item.slug}`} class={`card overflow-hidden group stagger-item stagger-${i + 2}`}>
        <div class="aspect-[4/3] overflow-hidden bg-bg-tertiary">
          {item.image ? (
            <img src={item.image} alt={item.title} class="w-full h-full object-cover motion-image group-hover:scale-[1.02]" loading="lazy" />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-text-tertiary/20">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            </div>
          )}
        </div>
        <div class="p-4 md:p-5">
          <span class="text-[11px] font-medium uppercase tracking-wider text-accent-blue mb-1.5 inline-block">
            {item.collection === "news" ? "新闻" : "赛事"}
          </span>
          <h3 class="text-base font-semibold text-text-primary group-hover:text-accent-blue transition-colors mb-1.5">{item.title}</h3>
          <p class="text-xs text-text-tertiary line-clamp-2">{item.summary}</p>
          <span class="text-[11px] text-text-tertiary mt-2 inline-block">{item.date.toISOString().slice(0, 10)}</span>
        </div>
      </a>
    ))}
  </div>
</div>
