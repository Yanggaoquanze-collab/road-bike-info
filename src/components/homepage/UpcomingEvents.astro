---
import type { CollectionEntry } from "astro:content";
import EventCard from "../events/EventCard.astro";
import { slugify } from "../../lib/constants";

interface Props {
  items: CollectionEntry<"events">[];
}

const { items } = Astro.props;
---

<div>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-xl font-bold text-text-primary">近期赛事</h2>
      <p class="text-sm text-text-tertiary mt-1">即将开始的比赛</p>
    </div>
    <a href="/events" class="text-sm text-accent-blue hover:text-blue-400 transition-colors">查看全部 &rarr;</a>
  </div>
  <div class="grid gap-4 md:grid-cols-3">
    {items.map(item => (
      <EventCard {...item.data} slug={slugify(item.id)} />
    ))}
    {items.length === 0 && (
      <p class="text-text-tertiary col-span-full text-center py-8">暂无近期赛事</p>
    )}
  </div>
</div>
