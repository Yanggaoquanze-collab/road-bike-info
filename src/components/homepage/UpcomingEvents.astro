---
import type { CollectionEntry } from "astro:content";
import EventCard from "../events/EventCard.astro";
import { slugify } from "../../lib/constants";

interface Props {
  items: CollectionEntry<"events">[];
}

const { items } = Astro.props;
---

<div>
  <div class="mb-8">
    <h2 class="section-title mb-1">近期赛事</h2>
    <p class="section-subtitle">即将开始的比赛</p>
    <a href="/events" class="inline-block text-sm text-text-tertiary hover:text-text-secondary transition-colors mt-3">查看全部 &rarr;</a>
  </div>

  <div class="divide-y divide-surface-border">
    {items.map(item => (
      <EventCard {...item.data} slug={slugify(item.id)} />
    ))}
    {items.length === 0 && (
      <p class="text-meta text-center py-12">暂无近期赛事</p>
    )}
  </div>
</div>
