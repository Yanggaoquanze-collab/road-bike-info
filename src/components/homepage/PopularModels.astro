---
import type { CollectionEntry } from "astro:content";
import BikeMagazineCard from "../bikes/BikeMagazineCard.astro";
import { slugify } from "../../lib/constants";

interface Props {
  items: CollectionEntry<"bikes">[];
}

const { items } = Astro.props;
---

<div>
  <div class="mb-8">
    <h2 class="section-title mb-1">精选车型</h2>
    <p class="section-subtitle">值得关注的最新公路车</p>
    <a href="/bikes" class="inline-block text-sm text-text-tertiary hover:text-text-secondary transition-colors mt-3">查看全部 &rarr;</a>
  </div>

  <!-- 2-column photo directory, uniform 4:5 ratio -->
  <div class="grid gap-x-8 gap-y-12 grid-cols-1 md:grid-cols-2">
    {items.slice(0, 4).map(item => (
      <BikeMagazineCard {...item.data} slug={slugify(item.id)} />
    ))}
  </div>
</div>
