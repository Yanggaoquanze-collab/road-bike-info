---
import type { CollectionEntry } from "astro:content";
import BikeMagazineCard from "../bikes/BikeMagazineCard.astro";
import { slugify } from "../../lib/constants";

interface Props {
  items: CollectionEntry<"bikes">[];
}

const { items } = Astro.props;
---

<div>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-xl font-bold text-text-primary">热门车型</h2>
      <p class="text-sm text-text-tertiary mt-1">精选公路车推荐</p>
    </div>
    <a href="/bikes" class="text-sm text-accent-blue hover:text-accent-blue transition-colors">查看全部 &rarr;</a>
  </div>

  <!-- asymmetric magazine grid: 3-col base, varied spans -->
  <div class="grid gap-5 grid-cols-1 md:grid-cols-3">
    {items.slice(0, 4).map((item, i) => {
      const layouts = [
        { col: "md:col-span-2", aspect: "16/9" },
        { col: "md:col-span-1", aspect: "3/4" },
        { col: "md:col-span-1", aspect: "3/4" },
        { col: "md:col-span-2", aspect: "16/9" },
      ];
      const layout = layouts[i];
      return (
        <div class={layout.col}>
          <BikeMagazineCard {...item.data} slug={slugify(item.id)} aspect={layout.aspect} />
        </div>
      );
    })}
  </div>
</div>
