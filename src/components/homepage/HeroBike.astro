<div class="relative max-w-[1280px] mx-auto px-6 text-center py-8 md:py-16">
  <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-text-primary tracking-tight mb-4">
    骑迹
  </h1>
  <p class="text-lg md:text-xl text-text-secondary max-w-2xl mx-auto mb-8">
    公路车新闻、赛事、维修、车型 — 骑行爱好者的一站式平台
  </p>

  <div class="flex justify-center gap-4 mb-10">
    <a href="/news" class="btn btn-primary">浏览新闻</a>
    <a href="/bikes" class="btn btn-secondary">查看车型</a>
  </div>

  <div class="flex justify-center gap-6 text-sm text-text-secondary mb-8">
    <span class="flex items-center gap-1.5">
      <span class="w-1.5 h-1.5 rounded-full bg-accent-blue"></span> 每日资讯
    </span>
    <span class="flex items-center gap-1.5">
      <span class="w-1.5 h-1.5 rounded-full bg-accent-purple"></span> 车型数据库
    </span>
    <span class="flex items-center gap-1.5">
      <span class="w-1.5 h-1.5 rounded-full bg-accent-green"></span> 维修指南
    </span>
  </div>

  <div class="w-24 h-px bg-surface-border mx-auto mb-8"></div>

  <p class="text-sm text-text-tertiary">
    最新收录 <span class="text-accent-blue font-semibold">120+</span> 车型
  </p>
</div>
