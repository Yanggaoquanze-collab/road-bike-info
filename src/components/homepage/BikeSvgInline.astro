<!-- 公路车 SVG 线稿 — 侧面，车头朝右，露出牙盘 -->
<svg viewBox="0 0 800 420" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
  <defs>
    <linearGradient id="bikeGrad" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#3b82f6" />
      <stop offset="100%" stop-color="#8b5cf6" />
    </linearGradient>
    <linearGradient id="glowGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.3" />
      <stop offset="100%" stop-color="#8b5cf6" stop-opacity="0" />
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="6" result="blur" />
      <feMerge><feMergeNode in="blur" /><feMergeNode in="SourceGraphic" /></feMerge>
    </filter>
    <radialGradient id="grid" cx="50%" cy="50%">
      <stop offset="0%" stop-color="#1a1a26" stop-opacity="0.5" />
      <stop offset="100%" stop-color="#0a0a0f" stop-opacity="0" />
    </radialGradient>
  </defs>

  <rect x="0" y="0" width="800" height="420" fill="url(#grid)" />

  <!-- ===== 后轮 ===== -->
  <g id="hotspot-rear-wheel" data-section="/maintenance" data-category="轮组" data-label="后轮/轮组" class="hotspot-area cursor-pointer">
    <circle cx="185" cy="295" r="110" fill="none" stroke="url(#bikeGrad)" stroke-width="2" opacity="0.6" />
    <circle cx="185" cy="295" r="6" fill="url(#bikeGrad)" />
    {Array.from({ length: 8 }, (_, i) => {
      const angle = (i * Math.PI * 2) / 8;
      return <line x1={185 + 6 * Math.cos(angle)} y1={295 + 6 * Math.sin(angle)} x2={185 + 104 * Math.cos(angle)} y2={295 + 104 * Math.sin(angle)} stroke="url(#bikeGrad)" stroke-width="0.8" opacity="0.25" />;
    })}
    <circle cx="185" cy="295" r="108" fill="transparent" class="hotspot-bg" />
  </g>

  <!-- ===== 前轮 ===== -->
  <g id="hotspot-front-wheel" data-section="/maintenance" data-category="轮组" data-label="前轮/轮组" class="hotspot-area cursor-pointer">
    <circle cx="645" cy="295" r="110" fill="none" stroke="url(#bikeGrad)" stroke-width="2" opacity="0.6" />
    <circle cx="645" cy="295" r="6" fill="url(#bikeGrad)" />
    {Array.from({ length: 8 }, (_, i) => {
      const angle = (i * Math.PI * 2) / 8;
      return <line x1={645 + 6 * Math.cos(angle)} y1={295 + 6 * Math.sin(angle)} x2={645 + 104 * Math.cos(angle)} y2={295 + 104 * Math.sin(angle)} stroke="url(#bikeGrad)" stroke-width="0.8" opacity="0.25" />;
    })}
    <circle cx="645" cy="295" r="108" fill="transparent" class="hotspot-bg" />
  </g>

  <!-- ===== 车架主体 ===== -->
  <g class="frame-group">
    <line x1="185" y1="295" x2="300" y2="255" stroke="url(#bikeGrad)" stroke-width="3.5" stroke-linecap="round" />
    <line x1="185" y1="295" x2="330" y2="170" stroke="url(#bikeGrad)" stroke-width="2.5" stroke-linecap="round" />
    <line x1="300" y1="255" x2="330" y2="170" stroke="url(#bikeGrad)" stroke-width="4" stroke-linecap="round" />
    <line x1="300" y1="255" x2="550" y2="185" stroke="url(#bikeGrad)" stroke-width="4.5" stroke-linecap="round" />
    <line x1="330" y1="170" x2="570" y2="168" stroke="url(#bikeGrad)" stroke-width="3" stroke-linecap="round" />
    <line x1="550" y1="185" x2="570" y2="168" stroke="url(#bikeGrad)" stroke-width="4.5" stroke-linecap="round" />
    <path d="M 558 178 Q 590 230 645 295" fill="none" stroke="url(#bikeGrad)" stroke-width="3" stroke-linecap="round" />
  </g>

  <!-- ===== 车架热区 ===== -->
  <g id="hotspot-frame" data-section="/bikes" data-label="查看车型库" class="hotspot-area cursor-pointer">
    <polygon points="330,170 300,255 550,185 570,168" fill="transparent" class="hotspot-bg" />
  </g>

  <!-- ===== 坐垫/座管 ===== -->
  <g id="hotspot-saddle" data-section="/maintenance" data-category="车架" data-label="坐垫/座管" class="hotspot-area cursor-pointer">
    <line x1="330" y1="170" x2="315" y2="115" stroke="url(#bikeGrad)" stroke-width="3" stroke-linecap="round" />
    <path d="M 290 112 Q 315 105 345 112 Q 350 118 345 122 L 290 118 Z" fill="none" stroke="url(#bikeGrad)" stroke-width="3" stroke-linejoin="round" />
    <path d="M 290 112 Q 315 105 345 112 Q 350 118 345 122 L 290 118 Z" fill="transparent" class="hotspot-bg" />
  </g>

  <!-- ===== 车把/手变 ===== -->
  <g id="hotspot-handlebar" data-section="/maintenance" data-category="变速" data-label="手变/车把" class="hotspot-area cursor-pointer">
    <line x1="570" y1="168" x2="585" y2="148" stroke="url(#bikeGrad)" stroke-width="2.5" stroke-linecap="round" />
    <path d="M 560 142 Q 585 135 620 142 Q 635 160 620 175" fill="none" stroke="url(#bikeGrad)" stroke-width="3" stroke-linecap="round" />
    <path d="M 615 148 Q 620 160 615 170" fill="none" stroke="url(#bikeGrad)" stroke-width="3" stroke-linecap="round" />
    <path d="M 555 140 Q 585 130 625 140 Q 640 155 625 180" fill="transparent" class="hotspot-bg" />
  </g>

  <!-- ===== 牙盘/曲柄 ===== -->
  <g id="hotspot-crankset" data-section="/maintenance" data-category="传动系统" data-label="牙盘/传动系统" class="hotspot-area cursor-pointer">
    <circle cx="310" cy="255" r="28" fill="none" stroke="url(#bikeGrad)" stroke-width="3" />
    <circle cx="310" cy="255" r="20" fill="none" stroke="url(#bikeGrad)" stroke-width="1.5" opacity="0.5" />
    <circle cx="310" cy="255" r="8" fill="url(#bikeGrad)" opacity="0.6" />
    <line x1="310" y1="255" x2="295" y2="225" stroke="url(#bikeGrad)" stroke-width="3.5" stroke-linecap="round" />
    <line x1="292" y1="220" x2="298" y2="230" stroke="url(#bikeGrad)" stroke-width="3" stroke-linecap="round" />
    <circle cx="280" cy="265" r="6" fill="none" stroke="url(#bikeGrad)" stroke-width="2" opacity="0.6" />
    <circle cx="280" cy="260" r="4" fill="none" stroke="url(#bikeGrad)" stroke-width="1.5" opacity="0.4" />
    <line x1="338" y1="255" x2="280" y2="258" stroke="url(#bikeGrad)" stroke-width="1.5" opacity="0.5" />
    <line x1="282" y1="290" x2="310" y2="283" stroke="url(#bikeGrad)" stroke-width="1.5" opacity="0.5" />
    <line x1="282" y1="290" x2="185" y2="310" stroke="url(#bikeGrad)" stroke-width="1.5" opacity="0.4" />
    <circle cx="310" cy="255" r="32" fill="transparent" class="hotspot-bg" />
  </g>

  <text x="400" y="380" text-anchor="middle" fill="#1a1a26" font-size="11" font-family="Inter, sans-serif" font-weight="600" letter-spacing="4">
    ROAD BIKE
  </text>
</svg>
