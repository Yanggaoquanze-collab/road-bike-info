---
interface Props {
  label: string;
  color?: "blue" | "purple" | "amber" | "green" | "red" | "default";
  size?: "sm" | "md";
}

const colorMap = {
  blue: "bg-blue-500/10 text-blue-400 border-blue-500/20",
  purple: "bg-purple-500/10 text-purple-400 border-purple-500/20",
  amber: "bg-amber-500/10 text-amber-400 border-amber-500/20",
  green: "bg-emerald-500/10 text-emerald-400 border-emerald-500/20",
  red: "bg-red-500/10 text-red-400 border-red-500/20",
  default: "bg-bg-tertiary text-text-tertiary border-surface-border",
};

const sizeMap = {
  sm: "px-2 py-0.5 text-xs",
  md: "px-3 py-1 text-xs",
};

const { label, color = "default", size = "md" } = Astro.props;
---

<span class={`inline-block rounded-full border ${colorMap[color]} ${sizeMap[size]} font-medium`}>
  {label}
</span>
