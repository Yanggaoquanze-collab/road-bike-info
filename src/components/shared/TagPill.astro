---
interface Props {
  label: string;
  color?: "blue" | "purple" | "amber" | "green" | "red" | "default";
  size?: "sm" | "md";
}

const colorMap = {
  blue: "text-[#2c5f8a]",
  purple: "text-[#7c5aa8]",
  amber: "text-[#e88a20]",
  green: "text-[#4a9e6b]",
  red: "text-[#d6403a]",
  default: "text-text-tertiary",
};

const sizeMap = {
  sm: "text-[11px]",
  md: "text-xs",
};

const { label, color = "default", size = "md" } = Astro.props;
---

<span class={`${colorMap[color]} ${sizeMap[size]} font-medium`}>
  {label}
</span>
