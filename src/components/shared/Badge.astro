---
interface Props {
  label: string;
  variant?: "fill" | "outline";
  color?: "blue" | "purple" | "amber" | "green" | "red" | "default";
}

const fillMap: Record<string, string> = {
  blue: "bg-[#2c5f8a] text-white",
  purple: "bg-[#7c5aa8] text-white",
  amber: "bg-[#e88a20] text-black",
  green: "bg-[#4a9e6b] text-white",
  red: "bg-[#d6403a] text-white",
  default: "bg-text-tertiary text-white",
};

const outlineMap: Record<string, string> = {
  blue: "text-[#2c5f8a]",
  purple: "text-[#7c5aa8]",
  amber: "text-[#e88a20]",
  green: "text-[#4a9e6b]",
  red: "text-[#d6403a]",
  default: "text-text-tertiary",
};

const { label, variant = "fill", color = "default" } = Astro.props;
const styleClass = variant === "fill" ? fillMap[color] : outlineMap[color];
const padding = variant === "fill" ? "px-2 py-0.5" : "";
---

<span class={`inline-block text-xs font-semibold ${styleClass} ${padding}`}>
  {label}
</span>
