---
interface SpecItem {
  label: string;
  value: string;
}

interface Props {
  bike: {
    brand: string;
    model: string;
    year: number;
    frame: string;
    fork?: string;
    groupset: string;
    groupsetType: string;
    brakes: string;
    wheels: string;
    tires?: string;
    weight: number;
    sizes: string[];
  };
}

const { bike } = Astro.props;
const groupsetTypeLabel = bike.groupsetType === "electronic" ? "电子变速" : "机械变速";

const specs: SpecItem[] = [
  { label: "车架", value: bike.frame },
  { label: "前叉", value: bike.fork || bike.frame },
  { label: "套件", value: `${bike.groupset}（${groupsetTypeLabel}）` },
  { label: "刹车", value: bike.brakes },
  { label: "轮组", value: bike.wheels },
  { label: "外胎", value: bike.tires || "-" },
  { label: "重量", value: `${bike.weight} kg` },
  { label: "尺码", value: bike.sizes.join(" / ") },
];
---

<div class="space-y-0">
  {specs.map((spec) => (
    <div class="flex items-baseline border-b border-surface-border py-4 gap-6">
      <span class="text-xs text-text-tertiary w-16 flex-shrink-0 uppercase tracking-wider">{spec.label}</span>
      <span class="text-sm text-text-primary">{spec.value}</span>
    </div>
  ))}
</div>
