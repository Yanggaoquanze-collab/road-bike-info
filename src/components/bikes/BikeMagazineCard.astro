---
import { BIKE_CATEGORIES } from "../../lib/constants";

interface Props {
  brand: string;
  model: string;
  year: number;
  category: keyof typeof BIKE_CATEGORIES;
  price: number;
  groupset: string;
  weight: number;
  image: string;
  slug: string;
}

const { brand, model, year, category, price, groupset, weight, image, slug } = Astro.props;
const catLabel = BIKE_CATEGORIES[category];
const formattedPrice = price >= 10000 ? `${(price / 10000).toFixed(2)} 万` : `¥${price.toLocaleString()}`;
---

<a href={`/bikes/${slug}`} class="group block">
  <!-- uniform 4:5 image, no border, no radius -->
  <div class="aspect-[3/2] overflow-hidden bg-bg-tertiary mb-4">
    <img src={image} alt={`${brand} ${model}`} class="w-full h-full object-cover motion-image group-hover:scale-[1.03]" loading="lazy" />
  </div>

  <!-- minimal text: brand + model only -->
  <div class="flex items-center gap-2 text-meta mb-1">
    <span>{brand}</span>
    <span class="text-text-tertiary/40">·</span>
    <span>{catLabel}</span>
  </div>
  <h3 class="font-display font-semibold text-xl text-text-primary group-hover:text-accent-blue transition-colors leading-snug">
    {model} ({year})
  </h3>
  <p class="text-meta mt-1">{groupset} · {formattedPrice} · {weight}kg</p>
</a>
