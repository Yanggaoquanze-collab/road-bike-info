---
import { BIKE_CATEGORIES } from "../../lib/constants";

interface Props {
  brand: string;
  model: string;
  year: number;
  category: keyof typeof BIKE_CATEGORIES;
  price: number;
  groupset: string;
  weight: number;
  image: string;
  slug: string;
}

const { brand, model, year, category, price, groupset, weight, image, slug } = Astro.props;
const catLabel = BIKE_CATEGORIES[category];
const formattedPrice = price >= 10000 ? `${(price / 10000).toFixed(2)} 万` : `¥${price.toLocaleString()}`;
---

<a href={`/bikes/${slug}`} class="card overflow-hidden group">
  <div class="aspect-[16/10] overflow-hidden bg-bg-tertiary">
    <img src={image} alt={`${brand} ${model}`} class="w-full h-full object-cover motion-image group-hover:scale-[1.03]" loading="lazy" />
  </div>
  <div class="p-5">
    <div class="flex items-center gap-2 mb-1.5">
      <span class="text-xs text-text-tertiary">{brand}</span>
      <span class="text-[11px] text-text-tertiary/50">·</span>
      <span class="text-xs text-text-tertiary">{catLabel}</span>
    </div>
    <h3 class="text-lg font-bold text-text-primary group-hover:text-accent-blue transition-colors mb-1.5">{model} ({year})</h3>
    <p class="text-sm text-text-secondary">{groupset} · {formattedPrice} · {weight}kg</p>
  </div>
</a>
