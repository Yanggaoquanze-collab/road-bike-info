---
import Badge from "../shared/Badge.astro";
import TagPill from "../shared/TagPill.astro";
import { EVENT_LEVELS, EVENT_TYPES } from "../../lib/constants";

interface Props {
  title: string;
  level: keyof typeof EVENT_LEVELS;
  type: keyof typeof EVENT_TYPES;
  region: string;
  country: string;
  startDate: Date;
  endDate: Date;
  location: string;
  status: string;
  summary: string;
  tags: string[];
  slug: string;
}

const { title, level, type, region, country, startDate, endDate, location, status, summary, tags, slug } = Astro.props;
const levelInfo = EVENT_LEVELS[level];
const typeLabel = EVENT_TYPES[type];
const statusLabel = status === "upcoming" ? "即将开始" : status === "ongoing" ? "进行中" : "已结束";
const statusColor = status === "upcoming" ? "green" : status === "ongoing" ? "amber" : "default";
---

<a href={`/events/${slug}`} class="card p-5 group block">
  <div class="flex items-center gap-2 mb-3">
    <span class={`inline-block w-2 h-2 rounded-full flex-shrink-0 ${status === "upcoming" ? "bg-accent-green" : status === "ongoing" ? "bg-accent-amber" : "bg-text-tertiary"}`}></span>
    <span class="text-[11px] font-medium uppercase tracking-wider text-text-tertiary">{statusLabel}</span>
    <span class="text-text-tertiary/50">·</span>
    <span class="text-[11px] text-text-tertiary">{typeLabel}</span>
  </div>
  <h3 class="font-semibold text-text-primary group-hover:text-accent-blue transition-colors mb-2 leading-snug">{title}</h3>
  <p class="text-sm text-text-secondary line-clamp-2 mb-3 leading-relaxed">{summary}</p>
  <div class="flex flex-wrap items-center gap-1.5 mb-3">
    <Badge label={levelInfo.label} color={levelInfo.color} variant="outline" />
    <TagPill label={region === "domestic" ? "国内" : "国际"} size="sm" color={region === "domestic" ? "green" : "blue"} />
  </div>
  <div class="flex items-center gap-2 pt-3 border-t border-surface-border text-xs text-text-tertiary">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="flex-shrink-0"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    <span>{startDate.toISOString().slice(0, 10)}{startDate.getTime() !== endDate.getTime() ? ` — ${endDate.toISOString().slice(0, 10)}` : ""}</span>
    <span>·</span>
    <span>{location}</span>
  </div>
</a>
