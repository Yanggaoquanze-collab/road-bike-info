---
import { EVENT_LEVELS, EVENT_TYPES } from "../../lib/constants";

interface Props {
  title: string;
  level: keyof typeof EVENT_LEVELS;
  type: keyof typeof EVENT_TYPES;
  region: string;
  country: string;
  startDate: Date;
  endDate: Date;
  location: string;
  status: string;
  summary: string;
  tags: string[];
  slug: string;
}

const { title, level, type, region, startDate, endDate, location, status, summary, slug } = Astro.props;
const levelInfo = EVENT_LEVELS[level];
const typeLabel = EVENT_TYPES[type];
const statusDot = status === "upcoming" ? "bg-accent-green" : status === "ongoing" ? "bg-accent-amber" : "bg-text-tertiary";
---

<a href={`/events/${slug}`} class="group flex items-center gap-4 md:gap-6 py-4 hover:bg-bg-secondary/50 transition-colors px-2 -mx-2">
  <!-- status dot -->
  <span class={`inline-block w-2 h-2 rounded-full flex-shrink-0 ${statusDot}`}></span>

  <!-- date -->
  <span class="text-meta flex-shrink-0 w-[7.5rem] tabular-nums">
    {startDate.toISOString().slice(0, 10)}
    {startDate.getTime() !== endDate.getTime() ? ` — ${endDate.toISOString().slice(0, 10)}` : ""}
  </span>

  <!-- main info -->
  <div class="min-w-0 flex-1">
    <h3 class="text-sm font-medium text-text-primary group-hover:text-accent-blue transition-colors leading-snug">{title}</h3>
    <p class="text-meta mt-0.5">{location} · {typeLabel} · {levelInfo.label}</p>
  </div>

  <!-- region tag — minimal -->
  <span class="text-[11px] text-text-tertiary flex-shrink-0 hidden sm:block">{region === "domestic" ? "国内" : "国际"}</span>
</a>
