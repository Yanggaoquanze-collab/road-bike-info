---
import { DIFFICULTY } from "../../lib/constants";

interface Props {
  title: string;
  category: string;
  difficulty: keyof typeof DIFFICULTY;
  symptoms: string[];
  tags: string[];
  slug: string;
}

const { title, category, difficulty, symptoms, tags, slug } = Astro.props;
const diff = DIFFICULTY[difficulty];
const keywords = [...new Set([...symptoms.slice(0, 3), ...tags.slice(0, 2)])].slice(0, 5).join(" · ");
const searchText = [title, category, ...symptoms, ...tags].join(" ");
---

<a
  href={`/maintenance/${slug}`}
  class="block py-5 border-t border-surface-border maintenance-card"
  data-search-text={searchText}
>
  <span class="text-meta">
    <span class="inline-block w-1.5 h-1.5 rounded-full bg-text-tertiary align-middle mr-1.5"></span>
    {diff.label}
  </span>
  <h3 class="text-base font-medium text-text-primary mt-1.5 mb-1">{title}</h3>
  <p class="text-meta">{keywords}</p>
</a>
