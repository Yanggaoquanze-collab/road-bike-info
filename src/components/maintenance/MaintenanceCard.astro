---
import TagPill from "../shared/TagPill.astro";
import { DIFFICULTY } from "../../lib/constants";

interface Props {
  title: string;
  category: string;
  difficulty: keyof typeof DIFFICULTY;
  symptoms: string[];
  tags: string[];
  slug: string;
}

const { title, category, difficulty, symptoms, tags, slug } = Astro.props;
const diff = DIFFICULTY[difficulty];
const diffColor = { green: "bg-accent-green", amber: "bg-accent-amber", red: "bg-accent-red" }[diff.color];
const searchText = [title, category, ...symptoms, ...tags].join(" ");
---

<a href={`/maintenance/${slug}`} class="card p-5 group maintenance-card" data-search-text={searchText}>
  <div class="flex items-center gap-2 mb-2">
    <span class={`inline-block w-2 h-2 rounded-full ${diffColor}`} />
    <span class="text-xs text-text-tertiary">{diff.label}</span>
    <TagPill label={category} size="sm" color="blue" />
  </div>
  <h3 class="font-semibold text-text-primary group-hover:text-accent-blue transition-colors mb-3">{title}</h3>
  <div class="flex flex-wrap gap-1.5">
    {tags.slice(0, 4).map(t => <TagPill label={t} size="sm" />)}
  </div>
</a>
