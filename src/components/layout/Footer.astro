---
import { SITE } from "../../config";
---

<footer class="mt-20" style="background: linear-gradient(180deg, #1a1a2e 0%, #0d0d1a 100%);">
  <div class="mx-auto max-w-[1200px] px-6 py-12">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-3">
        <svg width="20" height="20" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="25" cy="24" r="4.5" stroke="#c83c28" stroke-width="2"/>
          <circle cx="7" cy="24" r="4.5" stroke="#5a9ecf" stroke-width="2"/>
          <path d="M7 24 L10 8 L16 4 L22 8 L25 24" stroke="#c83c28" stroke-width="2" fill="none" stroke-linejoin="round"/>
        </svg>
        <span class="font-data text-[12px] tracking-[0.04em] text-white/50">{SITE.title} &copy; 2026</span>
      </div>
      <div class="flex items-center gap-6 text-[12px] tracking-[0.04em] text-white/35">
        <a href="/about" class="hover:text-white/60 transition-colors duration-200">关于本站</a>
        <span class="text-white/20">Built with Astro</span>
      </div>
    </div>
    <p class="text-center text-[11px] tracking-[0.04em] text-white/16 mt-6">在风里，找到速度的意义。</p>
  </div>
</footer>
